{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "C/C++: g++ build active file",
      "command": "mkdir -p \"${workspaceFolder}/build\" && g++ -fdiagnostics-color=always -std=c++17 -O2 -Wall -g \"${file}\" -o \"${workspaceFolder}/build/${fileBasenameNoExtension}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Compile the active .cpp with g++ into the build/ folder"
    }
  ]
}
